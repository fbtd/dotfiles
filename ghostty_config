# theme = dayfox
# theme = rose-pine-dawn
# theme = Dayfox
theme = Ayu Light
# background-opacity = 0.93
background-opacity = 0.88
alpha-blending = native
background = #FFFFFF
foreground = #000000
cursor-color = #f52798
selection-background = #f52798
# gtk-adwaita = false
window-decoration = false
font-family =  CaskaydiaCove Nerd Font Mono
font-feature = -liga, +calt, -dlig
# ~-  => {} <= != *** //
font-size = 16
# minimum-contrast = 1.3
# window-decoration = false
keybind = clear
keybind = super+v=paste_from_clipboard
keybind = performable:super+c=copy_to_clipboard
keybind = performable:alt+s>alt+s=toggle_command_palette
keybind = performable:alt+s>r=reload_config
keybind = performable:alt+s>i=inspector:toggle
